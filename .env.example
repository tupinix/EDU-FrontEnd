# ===========================================
# EDU Frontend - Environment Variables
# ===========================================
# Copy this file to .env if needed
# Most settings work with defaults for development

# API URL (optional - defaults to /api which uses Vite proxy)
# Set this for production or when backend is on different host
VITE_API_URL=/api

# MCP Server public URL (optional)
# Set this when using an HTTPS tunnel (ngrok, Cloudflare, etc.)
# so the frontend displays the correct URL for Claude Desktop / Claude Code.
# Example: VITE_MCP_URL=https://your-tunnel.ngrok-free.dev/mcp
# VITE_MCP_URL=

# WebSocket URL for real-time updates (future feature)
# VITE_WS_URL=ws://localhost:3000
